# Firebase web app config (Project settings -> General -> Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# football-data.org API key. No VITE_ prefix — used by the Vite dev proxy and
# the Netlify function (set it in Netlify Site settings -> Environment
# variables for production), never exposed to the client bundle.
FOOTBALL_API_KEY=
